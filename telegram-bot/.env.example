# ── Telegram ──
# Get this from @BotFather after creating your bot with /newbot
TELEGRAM_BOT_TOKEN=

# ── LTA DataMall ──
# Same key used by the main-site Vercel API routes (main-site/api/*.js).
# Request one at https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
LTA_ACCOUNT_KEY=

# ── Links used by /start ──
# Public URL of the main-site PWA (leave blank to hide the "Open Web App" button)
WEBAPP_URL=https://mrtalerts.uwuapps.org
# Donation link shown on /start
DONATE_URL=https://donate.stripe.com/28o2akeAr3hv0DK6oo

# ── Storage ──
# Path to the SQLite database file (created automatically on first run)
DB_PATH=./data/bot.sqlite3

# ── Scheduler ──
# How often (seconds) the bot polls LTA TrainServiceAlerts for /sub updates
ALERT_POLL_INTERVAL_SECONDS=60

# Note: the main-site Vercel project also defines SUPABASE_URL / SUPABASE_SERVICE_KEY /
# LTA_ACCOUNT_KEY as environment variables. This bot only needs LTA_ACCOUNT_KEY above -
# it uses its own local SQLite database instead of Supabase, so no Supabase credentials
# are required here.
